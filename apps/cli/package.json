{
  "name": "@clew/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "clew": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clew/core": "workspace:*",
    "@clew/providers": "workspace:*",
    "@clew/gateway": "workspace:*",
    "@clew/memory": "workspace:*",
    "@clew/taste": "workspace:*",
    "@clew/agents": "workspace:*",
    "@clew/tools": "workspace:*",
    "@clew/mcp": "workspace:*",
    "@clew/skills": "workspace:*",
    "commander": "^13.0.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
